# .env.example
# Copy to .env and fill in. Never commit the real .env.

# Neon Postgres connection string (use the pooled connection string).
# Example: postgresql://USER:PASSWORD@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Better Auth server secret. Generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Public base URL of the auth backend (the Expo server/web origin).
# Dev default is the Expo dev server. In production set your deployed URL.
EXPO_PUBLIC_AUTH_BASE_URL=http://localhost:8081
